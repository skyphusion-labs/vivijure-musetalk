# deploy.env -- keys and settings for ./deploy.sh (vivijure-musetalk, lip-sync).
# Copy this file to deploy.env, then fill it in. deploy.env is git-ignored; never commit it.

# ---- required ---------------------------------------------------------------

# Your RunPod API key. Get it at runpod.io -> Settings -> API Keys.
RUNPOD_API_KEY=

# The image to build and run. Point this at YOUR OWN registry (so you control the pushes).
# The default is our public image; change <you> to your own GitHub/registry user to publish your own.
IMAGE=ghcr.io/skyphusion-labs/vivijure-musetalk:latest

# A name for the RunPod endpoint. Any label you like.
ENDPOINT_NAME=vivijure-musetalk

# Which GPU(s) RunPod may run this on, comma-separated (first available is used).
# IMPORTANT: this image is CUDA 12.8 (cu128), which needs a NEW-driver host. Pin it to cards that
# are always on new drivers -- Blackwell (RTX PRO 6000) or Hopper (H100/H200). Cheap 4090/L40S hosts
# are a driver lottery for a cu128 image and can refuse to start. Copy a GPU name exactly as RunPod
# lists it.
GPU_TYPE_IDS=NVIDIA RTX PRO 6000 Blackwell Server Edition,NVIDIA H100 80GB HBM3

# ---- optional (sensible defaults; uncomment to change) ----------------------

# Container disk in GB. MuseTalk bakes ~7GB of model weights, so give it headroom.
CONTAINER_DISK_GB=30

# Autoscaling. workersMin 0 = scale to zero = pay nothing when idle.
# WORKERS_MIN=0
# WORKERS_MAX=2
# IDLE_TIMEOUT=5
# EXECUTION_TIMEOUT_MS=600000

# If your IMAGE is PRIVATE, RunPod needs a registry credential to pull it. Create one in the RunPod
# console (Settings -> Container Registry Auth) and put its id here. Leave blank for a PUBLIC image.
# CONTAINER_REGISTRY_AUTH_ID=

# Log in to your registry before pushing. Leave blank if you already ran 'docker login'.
# REGISTRY_USER=
# REGISTRY_TOKEN=

# R2 "finish-chain" mode: the endpoint reads the face clip + audio and writes the result straight to
# your R2 bucket by key. Set these to turn it on (the studio uses this mode). Leave blank to use only
# the presigned-URL mode, where the studio hands the endpoint temporary links instead.
# R2_ENDPOINT_URL=
# R2_BUCKET=vivijure
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Skip flags for re-runs. SKIP_BUILD=1 reuses an already-pushed image; SKIP_ENDPOINT=1 stops after push.
# SKIP_BUILD=0
# SKIP_ENDPOINT=0

# Printed at the end to remind you how to wire this into the studio. Do not need to change it.
STUDIO_ENV_HINT="In your vivijure Studio deploy.env set MUSETALK_RUNPOD_ENDPOINT_ID to the endpoint id above, keep VIVIJURE_PROFILE=full, and re-run the studio ./deploy.sh. This turns on the finish-lipsync module. See the studio docs/opt-in-tiers.md (finish-lipsync)."
